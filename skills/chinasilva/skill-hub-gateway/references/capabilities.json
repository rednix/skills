{
  "capabilities": [
    {
      "id": "human_detect",
      "service_id": "svc_cf_human_detect",
      "summary": "Detect human presence in image.",
      "input_schema": {
        "type": "object",
        "required": ["image_url"],
        "properties": {
          "image_url": { "type": "string", "format": "uri" }
        }
      },
      "example_input": {
        "image_url": "https://example.com/image.png"
      }
    },
    {
      "id": "image_tagging",
      "service_id": "svc_cf_image_tagging",
      "summary": "Generate tags from image.",
      "input_schema": {
        "type": "object",
        "required": ["image_url"],
        "properties": {
          "image_url": { "type": "string", "format": "uri" }
        }
      },
      "example_input": {
        "image_url": "https://example.com/image.png"
      }
    },
    {
      "id": "tts_report",
      "service_id": "svc_cf_tts_report",
      "summary": "Synthesize text to speech report.",
      "input_schema": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string", "maxLength": 4096 },
          "speaker": { "type": "string", "maxLength": 64 }
        }
      },
      "example_input": {
        "text": "hello from skill hub",
        "speaker": "alloy"
      }
    },
    {
      "id": "embeddings",
      "service_id": "svc_cf_embeddings",
      "summary": "Generate embeddings from texts.",
      "input_schema": {
        "type": "object",
        "required": ["texts"],
        "properties": {
          "texts": {
            "type": "array",
            "minItems": 1,
            "maxItems": 128,
            "items": { "type": "string", "maxLength": 8192 }
          },
          "truncate": { "type": "boolean" }
        }
      },
      "example_input": {
        "texts": ["hello world", "skill hub gateway"],
        "truncate": true
      }
    },
    {
      "id": "reranker",
      "service_id": "svc_cf_reranker",
      "summary": "Rerank documents for query.",
      "input_schema": {
        "type": "object",
        "required": ["query", "documents"],
        "properties": {
          "query": { "type": "string", "maxLength": 4096 },
          "documents": {
            "type": "array",
            "minItems": 1,
            "maxItems": 128,
            "items": { "type": "string", "maxLength": 8192 }
          },
          "top_k": { "type": "integer", "minimum": 1, "maximum": 128 }
        }
      },
      "example_input": {
        "query": "cloud cost optimization",
        "documents": ["doc1", "doc2"],
        "top_k": 2
      }
    },
    {
      "id": "asr",
      "service_id": "svc_cf_asr",
      "summary": "Transcribe audio URL.",
      "input_schema": {
        "type": "object",
        "required": ["audio_url"],
        "properties": {
          "audio_url": { "type": "string", "format": "uri" },
          "language": { "type": "string", "minLength": 2, "maxLength": 8 },
          "diarize": { "type": "boolean" }
        }
      },
      "example_input": {
        "audio_url": "https://example.com/audio.wav",
        "language": "en",
        "diarize": false
      }
    },
    {
      "id": "tts_low_cost",
      "service_id": "svc_cf_tts_low_cost",
      "summary": "Low-cost text to speech.",
      "input_schema": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string", "maxLength": 4096 },
          "speaker": { "type": "string", "maxLength": 64 }
        }
      },
      "example_input": {
        "text": "low-cost speech",
        "speaker": "alloy"
      }
    },
    {
      "id": "markdown_convert",
      "service_id": "svc_cf_markdown_convert",
      "summary": "Convert document URL to markdown.",
      "input_schema": {
        "type": "object",
        "required": ["file_url"],
        "properties": {
          "file_url": { "type": "string", "format": "uri" },
          "conversion_options": { "type": "object" }
        }
      },
      "example_input": {
        "file_url": "https://example.com/report.pdf",
        "conversion_options": { "preserve_tables": true }
      }
    }
  ]
}
